# Hermis Agent - Environment Configuration

# Core
HERMIS_ROOT=/opt/hermis
HERMIS_VERSION=1.0.0

# PostgreSQL
POSTGRES_USER=hermis
POSTGRES_PASSWORD=hermis_secure_password_2024
POSTGRES_DB=hermis

# Redis
REDIS_PASSWORD=redis_secure_password_2024

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_secure_password_2024
GRAFANA_SECRET_KEY=grafana_secret_key_change_me

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_secure_password_2024

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secure_password_2024

# Vault
VAULT_DEV_ROOT_TOKEN_ID=vault_root_token_change_me

# OpenWebUI (for future use)
OPENWEBUI_API_KEY=openwebui_api_key_change_me
OPENWEBUI_SECRET_KEY=openwebui_secret_key_change_me

# Qdrant
QDRANT_API_KEY=qdrant_api_key_change_me

# Portainer
PORTAINER_PASSWORD=portainer_password_change_me

# Docker
DOCKER_BUILDKIT=1

# Timezone
TZ=UTC
